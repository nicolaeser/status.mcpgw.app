{
  "name": "status.mcpgw.app",
  "version": "1.0.0",
  "author": "Nico Laeser",
  "description": "Status-focused MCP server for querying vendor status pages, incidents, components, and maintenance feeds.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "prettier": "npx prettier --write \"src/**/*.{js,jsx,ts,tsx,css,scss,json,md,yml,yaml}\"\n",
    "cu": "npx npm-check-updates -u"
  },
  "dependencies": {
    "express": "^5.2.1",
    "fast-xml-parser": "^5.7.1",
    "ioredis": "^5.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
